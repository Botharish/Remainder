# ---------------------------------------------------------------------------
# Convex
# ---------------------------------------------------------------------------
# Populated automatically when you run `npx convex dev`.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
# The .site URL of your deployment (Convex HTTP actions). Usually the same host
# as NEXT_PUBLIC_CONVEX_URL but with `.convex.site` instead of `.convex.cloud`.
NEXT_PUBLIC_CONVEX_SITE_URL=

# ---------------------------------------------------------------------------
# Better Auth
# ---------------------------------------------------------------------------
# Generate with: npx @better-auth/cli secret   (or: openssl rand -base64 32)
BETTER_AUTH_SECRET=
# The public URL of the Next.js app.
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Bootstrap admin
# The first user to sign up with this email is auto-promoted to admin + approved.
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
